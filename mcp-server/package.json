{
  "name": "chatmcp-server",
  "version": "1.0.0",
  "description": "MCP server that bridges Claude Code to your AI browser tabs (ChatGPT, Claude, Gemini, Grok, DeepSeek, Mistral, Perplexity)",
  "type": "module",
  "main": "dist/index.js",
  "author": "Rohit Gupta <indiantinker@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indiantinker/chatMCP.git"
  },
  "bugs": {
    "url": "https://github.com/indiantinker/chatMCP/issues"
  },
  "homepage": "https://github.com/indiantinker/chatMCP#readme",
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "chatgpt",
    "gemini",
    "browser",
    "context",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
